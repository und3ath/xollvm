#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>

__attribute__((noinline, annotate("{annotation}")))
uint32_t obf_target(uint32_t x, uint32_t y) {{
    int a = (int)x;
    int b = (int)y;
    int c = (int)(x + y);
    int d = (int)(x ^ y);

    int x1 = a + b;
    int y1 = c ^ d;
    int z;
    if (x1 > y1) {{
        z = x1 * (c & 0xFF);
        if (z > 1000) z = z - 1000;
    }} else {{
        z = y1 | (a & b);
    }}

    for (int i = 0; i < 3; ++i) {{
        if ((z + i) & 1) z ^= (a + i);
        else z += (b - i);
    }}

    return (uint32_t)(z ^ (x1 + y1));
}}

int main(int argc, char** argv) {{
    uint32_t x = (argc > 1) ? (uint32_t)strtoul(argv[1], 0, 0) : 123u;
    uint32_t y = (argc > 2) ? (uint32_t)strtoul(argv[2], 0, 0) : 456u;
    uint32_t r = obf_target(x, y);
    printf("R=%u\n", r);
    return (int)(r & 0xFFu);
}}
