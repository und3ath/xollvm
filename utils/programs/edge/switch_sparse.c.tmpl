#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>

__attribute__((noinline, annotate("{annotation}")))
uint32_t obf_target(uint32_t x, uint32_t y) {{
    /* Sparse switch — LLVM may lower to binary search or chained compares. */
    switch (x) {{
        case 0:          return y + 1u;
        case 7:          return y ^ 0xA5A5u;
        case 42:         return (y << 3) | 1u;
        case 0x100:      return y * 7u;
        case 0xABCD:     return y - 17u;
        case 0xDEADBEEF: return ~y;
        case 0xFFFFFFFF: return y ^ 0x55555555u;
        default:         return y + (x & 0xFFu);
    }}
}}

int main(int argc, char** argv) {{
    uint32_t x = (argc > 1) ? (uint32_t)strtoul(argv[1], 0, 0) : 42u;
    uint32_t y = (argc > 2) ? (uint32_t)strtoul(argv[2], 0, 0) : 100u;
    uint32_t r = obf_target(x, y);
    printf("R=%u\n", r);
    return (int)(r & 0xFFu);
}}
